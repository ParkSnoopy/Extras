{
    "version": "1.20.0-beta.3",
    "description": "User-friendly Desktop Client App for AI Models/LLMs (GPT, Claude, Gemini, Ollama...)",
    "homepage": "https://github.com/chatboxai/chatbox",
    "license": "GPL-3.0",
    "changelog": "https://github.com/chatboxai/chatbox/releases",
    "url": "https://download.chatboxai.app/releases/Chatbox-1.20.0-beta.3-Setup.exe",
    "hash": "ed7a854aab28e73075af50567b787e5e2c0ffada1db4f70e085cc6da9ca80ab5",
    "depends": "main/7zip",
    "architecture": {
        "64bit": {
            "pre_install": [
                "Expand-7zipArchive \"$dir\\$fname\" -Overwrite Rename -Removal",
                "Get-ChildItem -Recurse -File -Path \"$dir\" | Move-Item -Destination \"$dir\" -Force",
                "Expand-7zipArchive \"$dir\\app-64.7z\" -Overwrite Rename -Removal"
            ]
        },
        "arm64": {
            "pre_install": [
                "Expand-7zipArchive \"$dir\\$fname\" -Overwrite Rename -Removal",
                "Get-ChildItem -Recurse -File -Path \"$dir\" | Move-Item -Destination \"$dir\" -Force",
                "Expand-7zipArchive \"$dir\\app-arm64.7z\" -Overwrite Rename -Removal"
            ]
        }
    },
    "post_install": [
        "Remove-Item \"$dir\\$*\" -Recurse -Force -ErrorAction SilentlyContinue",
        "Remove-Item \"$dir\\Uninstall Chatbox.exe\" -Recurse -Force -ErrorAction SilentlyContinue",
        "Remove-Item \"$dir\\$PLUGINSDIR\\app-64.7z\" -Recurse -Force -ErrorAction SilentlyContinue",
        "Remove-Item \"$dir\\$PLUGINSDIR\\app-arm64.7z\" -Recurse -Force -ErrorAction SilentlyContinue"
    ],
    "bin": "Chatbox.exe",
    "shortcuts": [
        [
            "Chatbox.exe",
            "ChatBox"
        ]
    ],
    "checkver": {
        "url": "https://chatboxai.app/en/help-center/changelog",
        "regex": "v([\\d\\.]+(?:-[a-zA-Z0-9.]+)?) - "
    },
    "autoupdate": {
        "url": "https://download.chatboxai.app/releases/Chatbox-$version-Setup.exe"
    }
}
